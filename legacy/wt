#!/usr/bin/env bash
set -euo pipefail

ROOT="${WORKTREE_ROOT:-$HOME/dev}"

usage() {
    cat <<'EOF'
Usage: wt <command> <args>

Commands:
  create <repo> <branch>   Create a worktree (creates branch if it doesn't exist)
  list   <repo>            List all worktrees for a repo
  remove <repo> <branch>   Remove a worktree
  prune  <repo>            Prune stale worktree references

Use '.' as <repo> to refer to the repo in the current directory.
EOF
    exit 1
}

die() {
    echo "error: $1" >&2
    exit 1
}

sanitize_branch() {
    echo "${1//\//-}"
}

resolve_repo() {
    local repo="$1"
    if [[ "$repo" == "." ]]; then
        local toplevel
        toplevel="$(git rev-parse --show-toplevel 2>/dev/null)" \
            || die "current directory is not inside a git repository"
        basename "$toplevel"
    else
        echo "$repo"
    fi
}

require_repo() {
    local repo_dir="$ROOT/$1"
    [[ -d "$repo_dir" ]] || die "repository '$1' not found at $repo_dir"
    git -C "$repo_dir" rev-parse --git-dir >/dev/null 2>&1 \
        || die "'$repo_dir' is not a git repository"
}

cmd_create() {
    [[ $# -eq 2 ]] || { echo "Usage: wt create <repo> <branch>" >&2; exit 1; }
    local repo branch="$2"
    repo="$(resolve_repo "$1")"
    require_repo "$repo"

    local repo_dir="$ROOT/$repo"
    local worktrees_dir="$ROOT/${repo}-worktrees"
    local safe_branch
    safe_branch="$(sanitize_branch "$branch")"
    local wt_path="$worktrees_dir/$safe_branch"

    [[ -d "$wt_path" ]] && die "worktree already exists at $wt_path"

    mkdir -p "$worktrees_dir"

    if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
        git -C "$repo_dir" worktree add "$wt_path" "$branch"
    elif git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null; then
        git -C "$repo_dir" worktree add "$wt_path" "$branch"
    else
        git -C "$repo_dir" worktree add -b "$branch" "$wt_path"
    fi

    echo "Worktree created at $wt_path"
}

cmd_list() {
    [[ $# -eq 1 ]] || { echo "Usage: wt list <repo>" >&2; exit 1; }
    local repo
    repo="$(resolve_repo "$1")"
    require_repo "$repo"

    git -C "$ROOT/$repo" worktree list
}

cmd_remove() {
    [[ $# -eq 2 ]] || { echo "Usage: wt remove <repo> <branch>" >&2; exit 1; }
    local repo branch="$2"
    repo="$(resolve_repo "$1")"
    require_repo "$repo"

    local safe_branch
    safe_branch="$(sanitize_branch "$branch")"
    local wt_path="$ROOT/${repo}-worktrees/$safe_branch"

    [[ -d "$wt_path" ]] || die "worktree not found at $wt_path"

    git -C "$ROOT/$repo" worktree remove "$wt_path"
    echo "Worktree removed: $wt_path"
}

cmd_prune() {
    [[ $# -eq 1 ]] || { echo "Usage: wt prune <repo>" >&2; exit 1; }
    local repo
    repo="$(resolve_repo "$1")"
    require_repo "$repo"

    git -C "$ROOT/$repo" worktree prune -v
    echo "Pruned stale worktree references for $repo"
}

[[ $# -ge 1 ]] || usage

command="$1"
shift

case "$command" in
    create) cmd_create "$@" ;;
    list)   cmd_list "$@" ;;
    remove) cmd_remove "$@" ;;
    prune)  cmd_prune "$@" ;;
    *)      usage ;;
esac
